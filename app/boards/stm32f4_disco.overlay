 *
 * Overlay da STM32F4-Discovery (STM32F407VG) para o analisador de espectro.
 *
 * Fase F1: display OLED SSD1306 (128x64, I2C) no I2C1.
 *   O barramento I2C1 (SCL=PB6, SDA=PB9) ja vem habilitado pelo board, com
 *   pull-ups. O codec de audio CS43L22 (0x4a) compartilha esse barramento -
 *   sem conflito, pois os enderecos sao distintos (OLED = 0x3c).
 *
 * Fase F2: microfone INMP441 no I2S2 (CK=PB13, WS=PB12, SD=PB15). O CAN2 usa
 *   PB13 no board, entao e desabilitado aqui; o &i2s2 e habilitado com a fonte
 *   de clock PLLI2S (o canal de DMA RX ja vem do SoC dtsi).
 */

#include <zephyr/dt-bindings/clock/stm32f4_clock.h>

&i2c1 {
	ssd1306: ssd1306@3c {
		compatible = "solomon,ssd1306";
		reg = <0x3c>;
		width = <128>;
		height = <64>;
		segment-offset = <0>;
		page-offset = <0>;
		display-offset = <0>;
		multiplex-ratio = <63>;
		segment-remap;
		com-invdir;
		prechargep = <0x22>;
	};
};

/ {
	chosen {
		zephyr,display = &ssd1306;
	};
};

/* CAN2 ocupa o PB13 no board; liberamos para o I2S2_CK */
&can2 {
	status = "disabled";
};

/* microfone INMP441: I2S2 mestre-receptor (CK=PB13, WS=PB12, SD=PB15) */
&i2s2 {
	pinctrl-0 = <&i2s2_ck_pb13 &i2s2_ws_pb12 &i2s2_sd_pb15>;
	pinctrl-names = "default";
	clocks = <&rcc STM32_CLOCK(APB1, 14)>,
		 <&rcc STM32_SRC_PLLI2S_R I2S_SEL(0)>;
	status = "okay";
};
