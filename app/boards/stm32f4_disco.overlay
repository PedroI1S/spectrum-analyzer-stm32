 *
 * Overlay da STM32F4-Discovery (STM32F407VG) para o analisador de espectro.
 *
 * Fase F1: display OLED SSD1306 (128x64, I2C) no I2C1.
 *   O barramento I2C1 (SCL=PB6, SDA=PB9) ja vem habilitado pelo board, com
 *   pull-ups. O codec de audio CS43L22 (0x4a) compartilha esse barramento -
 *   sem conflito, pois os enderecos sao distintos (OLED = 0x3c).
 *
 * Fase F2 (a fazer): microfone INMP441 no I2S2 (CK=PB13, WS=PB12, SD=PB15).
 *   Como PB13 e usado pelo CAN2 no board, sera preciso desabilita-lo aqui:
 *     &can2 { status = "disabled"; };
 *   e habilitar &i2s2 com o clock PLLI2S e o canal de DMA RX.
 */

&i2c1 {
	ssd1306: ssd1306@3c {
		compatible = "solomon,ssd1306";
		reg = <0x3c>;
		width = <128>;
		height = <64>;
		segment-offset = <0>;
		page-offset = <0>;
		display-offset = <0>;
		multiplex-ratio = <63>;
		segment-remap;
		com-invdir;
		prechargep = <0x22>;
	};
};

/ {
	chosen {
		zephyr,display = &ssd1306;
	};
};
